# SQL Server
ConnectionStrings__DefaultConnection=Server=localhost;Database=AiMevzuat;Trusted_Connection=True;TrustServerCertificate=True;

# JWT (production'da guclu bir secret kullan)
Jwt__Secret=dev-local-jwt-secret-please-use-a-strong-value-123456
Jwt__Issuer=ai-mevzuat
Jwt__Audience=ai-mevzuat-client
Jwt__ExpiryMinutes=60

# AI Service
AiService__BaseUrl=http://localhost:8000
AiService__ApiKey=

# Mevzuat MCP
MevzuatMcp__Enabled=true
MevzuatMcp__BaseUrl=https://mevzuat.surucu.dev/mcp
MevzuatMcp__TimeoutSeconds=45
MevzuatMcp__UseDirectBedestenFallback=true

# Groq (opsiyonel)
GroqLlm__Enabled=false
GroqLlm__ApiKey=
GroqLlm__BaseUrl=https://api.groq.com/openai/v1
GroqLlm__Model=llama-3.3-70b-versatile
GroqLlm__FallbackModel=llama-3.1-8b-instant
GroqLlm__Temperature=0.2
GroqLlm__MaxTokens=700
GroqLlm__TimeoutSeconds=45

# Frontend origins
AllowedOrigins=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
